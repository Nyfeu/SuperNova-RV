#!/bin/bash

RED='\033[1;31m'
YELLOW='\033[1;33m'
DIM='\033[2m'
NC='\033[0m'

MSG_FILE=$1
REGEX="^(feat|fix|docs|style|refactor|perf|test|chore|ci|build)(\(.+\))?: .+"
COMMIT_MSG=$(head -n1 "$MSG_FILE")

if ! [[ "$COMMIT_MSG" =~ $REGEX ]]; then
  echo -e "${RED}✗ Invalid commit message format${NC}"
  echo -e "  Current message: ${DIM}'$COMMIT_MSG'${NC}\n"
  echo -e "  This project requires Conventional Commits:"
  echo -e "  ${YELLOW}<type>(<optional scope>): <description>${NC}\n"
  echo -e "  Valid examples:"
  echo -e "    feat: implement instruction decoder"
  echo -e "    fix(alu): fix overflow signal"
  exit 1
fi